# Copy this file to docker/.env and fill in local deployment secrets.
#
# Storage provider credentials and LLM provider credentials are managed in the UI
# and persisted in the database. Keep this file focused on deployment-level
# values and built-in tool keys that do not have a plugin credential UI yet.

# Core
JWT_SECRET_KEY=dev-jwt-secret-change-me-please-rotate
SETTING_CRYPTO_KEY=
SERVICE_IP=127.0.0.1
SERVICE_API_PREFIX=http://localhost:5011
UI_HOST_PORT=3100
API_HOST_PORT=5011

# PostgreSQL / Redis / Weaviate
POSTGRES_DB=llmops
POSTGRES_PASSWORD=llmops123456
REDIS_PASSWORD=llmops123456
WEAVIATE_API_KEY=dev-weaviate-api-key

# Local upload defaults. Other storage providers are configured in the UI.
LOCAL_STORAGE_ROOT=/app/api/storage/uploads
LOCAL_STORAGE_BASE_URL=http://localhost:3100/api/upload-files

# GitHub OAuth is optional for local development.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3100/auth/authorize/github

# Built-in tools that do not have a plugin credential UI yet.
GAODE_API_KEY=81e227126886f90338ca21ed111f99f9
SERPER_API_KEY=aeaf63872d6fd3cd22fcb7ed6f2e34154815250d

# Built-in assistant app id.
ASSISTANT_AGENT_ID=6774fcef-b594-8008-b30c-a05b8190afe6
