# Copy this file to docker/.env and fill in local secrets.

# Core
JWT_SECRET_KEY=dev-jwt-secret-change-me
SERVICE_IP=127.0.0.1
SERVICE_API_PREFIX=http://localhost:5001

# PostgreSQL / Redis / Weaviate
POSTGRES_DB=llmops
POSTGRES_PASSWORD=llmops123456
REDIS_PASSWORD=llmops123456
WEAVIATE_API_KEY=dev-weaviate-api-key

# Local uploads by default. Use cos for Tencent COS.
FILE_STORAGE_TYPE=local
LOCAL_STORAGE_ROOT=/app/api/storage/uploads
LOCAL_STORAGE_BASE_URL=http://localhost:3000/api/upload-files
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_SCHEME=https
COS_BUCKET=
COS_DOMAIN=

# GitHub OAuth is optional for local development.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/auth/authorize/github

# Default LLM for new apps.
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_MODEL=gpt-4o-mini
DEFAULT_LLM_TEMPERATURE=0.5
DEFAULT_LLM_TOP_P=0.85
DEFAULT_LLM_FREQUENCY_PENALTY=0.2
DEFAULT_LLM_PRESENCE_PENALTY=0.2
DEFAULT_LLM_MAX_TOKENS=8192

# LLM provider credentials.
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
MOONSHOT_API_KEY=
DASHSCOPE_API_KEY=
QIANFAN_AK=
QIANFAN_SK=

# Optional tracing and tools.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=LLMOpsDev
GAODE_API_KEY=
SERPER_API_KEY=

# Built-in assistant app id.
ASSISTANT_AGENT_ID=6774fcef-b594-8008-b30c-a05b8190afe6
