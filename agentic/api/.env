# 项目基础设置
ENV=development
LOG_LEVEL=DEBUG
APP_CONFIG_FILEPATH=config.yaml

# 本地存储根目录必须彼此独立：普通文件、不可变 Skill 包、Skill 草稿
LOCAL_STORAGE_PATH=/app/storage/files
SKILL_PACKAGE_STORAGE_PATH=/app/storage/skills/packages
SKILL_WORKSPACE_STORAGE_PATH=/app/storage/skill-workspaces
MARKETPLACE_SKILL_STORAGE_PROVIDER=local

# 数据库相关的配置
SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/manus

# Redis相关配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6479
REDIS_DB=0
REDIS_PASSWORD=

# 腾讯云cos相关配置
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=
COS_SCHEME=
COS_BUCKET=
COS_DOMAIN=

# 沙箱配置
SANDBOX_ADDRESS=
SANDBOX_IMAGE=manus-sandbox
SANDBOX_NAME_PREFIX=manus-sandbox
SANDBOX_TTL_MINUTES=60
SANDBOX_NETWORK=manus-network
SANDBOX_CHROME_ARGS=
SANDBOX_HTTPS_PROXY=
SANDBOX_HTTP_PROXY=
SANDBOX_NO_PROXY=
