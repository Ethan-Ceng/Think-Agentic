ENV=development
LOG_LEVEL=DEBUG
APP_CONFIG_FILEPATH=config.yaml

# 本地存储根目录必须彼此独立：普通文件、不可变 Skill 包、Skill 草稿
LOCAL_STORAGE_PATH=/app/storage/files
SKILL_PACKAGE_STORAGE_PATH=/app/storage/skills/packages
SKILL_WORKSPACE_STORAGE_PATH=/app/storage/skill-workspaces
MARKETPLACE_SKILL_STORAGE_PROVIDER=local

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=manus
SQLALCHEMY_DATABASE_URI=postgresql+asyncpg://postgres:postgres@manus-postgres:5432/manus

REDIS_HOST=manus-redis
REDIS_PORT=6479
REDIS_DB=0

COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_SCHEME=https
COS_BUCKET=
COS_DOMAIN=

SANDBOX_ADDRESS=manus-sandbox
SANDBOX_IMAGE=manus-sandbox
SANDBOX_NAME_PREFIX=manus-sandbox
SANDBOX_TTL_MINUTES=60
SANDBOX_NETWORK=manus-network
SANDBOX_CHROME_ARGS=
SANDBOX_HTTPS_PROXY=
SANDBOX_HTTP_PROXY=
SANDBOX_NO_PROXY=

NGINX_PORT=8088
